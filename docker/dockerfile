FROM nvidia/cuda:12.1.0-devel-ubuntu22.04

ENV TZ=US/Pacific
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# System packages
RUN apt-get update --fix-missing && \
    apt-get install -y libgtk2.0-dev && \
    apt-get install -y wget bzip2 ca-certificates curl git vim tmux g++ gcc \
        build-essential cmake checkinstall gfortran libjpeg8-dev libtiff5-dev \
        pkg-config yasm libavcodec-dev libavformat-dev libswscale-dev \
        libdc1394-dev libxine2-dev libv4l-dev libgtk2.0-dev libtbb-dev \
        libatlas-base-dev libmp3lame-dev libtheora-dev libvorbis-dev \
        libxvidcore-dev libopencore-amrnb-dev libopencore-amrwb-dev x264 \
        v4l-utils libprotobuf-dev protobuf-compiler libgoogle-glog-dev \
        libgflags-dev libgphoto2-dev libhdf5-dev doxygen libflann-dev \
        libboost-all-dev proj-data libproj-dev libyaml-cpp-dev \
        cmake-curses-gui libzmq3-dev freeglut3-dev gnupg2 lsb-release \
    && rm -rf /var/lib/apt/lists/*

# pybind11
RUN cd / && git clone https://github.com/pybind/pybind11 && \
    cd pybind11 && git checkout v2.10.0 && \
    mkdir build && cd build && \
    cmake .. -DCMAKE_BUILD_TYPE=Release -DPYBIND11_INSTALL=ON -DPYBIND11_TEST=OFF && \
    make -j6 && make install

# Eigen
RUN cd / && wget https://gitlab.com/libeigen/eigen/-/archive/3.4.0/eigen-3.4.0.tar.gz && \
    tar xvzf ./eigen-3.4.0.tar.gz && \
    cd eigen-3.4.0 && mkdir build && cd build && cmake .. && make install && \
    rm -rf /eigen-3.4.0 /eigen-3.4.0.tar.gz

SHELL ["/bin/bash", "--login", "-c"]

# Miniforge + single conda env `my` (Python 3.11).
# 3.11 instead of 3.9 so ROS2 Humble (RoboStack) fits in the same env,
# eliminating the dual-env complexity entirely.
RUN cd / && wget --quiet \
    https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh \
    -O /miniforge.sh && \
    /bin/bash /miniforge.sh -b -p /opt/conda && \
    rm /miniforge.sh && \
    ln -s /opt/conda/etc/profile.d/conda.sh /etc/profile.d/conda.sh && \
    echo ". /opt/conda/etc/profile.d/conda.sh" >> ~/.bashrc && \
    /opt/conda/bin/conda create -n my python=3.11 -y

ENV PATH $PATH:/opt/conda/envs/my/bin

# torch (CUDA 12.1) + pytorch3d in one RUN block.
# conda activate does not persist across RUN layers; ENV PATH above ensures
# the `my` env pip is used directly without needing activate.
RUN conda init bash && \
    echo "conda activate my" >> ~/.bashrc && \
    pip install "numpy<2" && \
    pip install torch==2.5.1+cu121 torchvision==0.20.1+cu121 torchaudio==2.5.1 \
        --index-url https://download.pytorch.org/whl/cu121 && \
    pip install fvcore iopath && \
    FORCE_CUDA=1 TORCH_CUDA_ARCH_LIST="8.9" \
        pip install "git+https://github.com/facebookresearch/pytorch3d.git@stable" \
        --no-build-isolation

# Remaining FoundationPose deps (torch already on PATH via ENV above)
RUN pip install scipy joblib scikit-learn ruamel.yaml "trimesh==3.23.5" pyyaml \
        "opencv-python==4.10.0.84" imageio open3d transformations warp-lang einops \
        kornia pyrender

# nvdiffrast (CUDA extension; arch 8.9 = RTX 4080 Ada)
RUN cd / && git clone https://github.com/NVlabs/nvdiffrast && \
    cd /nvdiffrast && \
    TORCH_CUDA_ARCH_LIST="8.9" pip install . --no-build-isolation

ENV OPENCV_IO_ENABLE_OPENEXR=1

# Remaining FoundationPose deps.
# Removed: nodejs, jupyterlab, objaverse, g4f, wandb, ultralytics, videoio
# — none are required for inference in the OI-MPPI pipeline.
RUN pip install scikit-image meshcat webdataset omegaconf pypng roma seaborn \
        "opencv-contrib-python==4.10.0.84" openpyxl imgaug Ninja xlsxwriter timm \
        albumentations xatlas rtree pycocotools numba && \
    conda run -n my conda install -y -c anaconda h5py

# Defensive re-pin: albumentations / opencv-contrib may have pulled numpy>=2
# or opencv-python-headless. Force the verified numpy 1.x + opencv 4.10 stack
# so pytorch3d / nvdiffrast (compiled against numpy 1.x) stay ABI-compatible.
RUN pip uninstall -y opencv-python-headless || true && \
    pip install "numpy==1.26.4" \
        "opencv-python==4.10.0.84" "opencv-contrib-python==4.10.0.84" \
        --force-reinstall --no-deps

ENV SHELL=/bin/bash
RUN ln -sf /bin/bash /bin/sh

# Cleanup
RUN conda run -n my pip cache purge || true \
    && conda clean -afy \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /root/.cache/pip
